<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:com="http://schemas.microsoft.com/appx/manifest/com/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap3 rescap">

  <!--
    Sparse package manifest — written to the install directory by build-exe.ps1.
    Gives the unpackaged EXE package identity so the Windows App Extension catalog
    (which PowerToys Command Palette uses) can discover the com.microsoft.commandpalette
    extension.  Registration happens in [Run] via Add-AppxPackage -ExternalLocation.

    __VERSION__ and __ARCH__ are replaced by build-exe.ps1 at build time.
  -->

  <Identity
    Name="PixelPusher247.HomeAssistantExtension"
    Publisher="CN=PixelPusher247"
    Version="__VERSION__"
    ProcessorArchitecture="__ARCH__" />

  <Properties>
    <DisplayName>Home Assistant Extension</DisplayName>
    <PublisherDisplayName>PixelPusher247</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-US" />
  </Resources>

  <Applications>
    <Application Id="App" Executable="HomeAssistantExtension.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Home Assistant"
        Description="Control Home Assistant devices from PowerToys Command Palette"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.scale-200.png"
        Square44x44Logo="Assets\Square44x44Logo.scale-200.png" />
      <Extensions>
        <com:Extension Category="windows.comServer">
          <com:ComServer>
            <com:ExeServer Executable="HomeAssistantExtension.exe" Arguments="-RegisterProcessAsComServer" DisplayName="Home Assistant">
              <com:Class Id="30267078-f12e-4d02-bec1-90657a71e804" DisplayName="Home Assistant" />
            </com:ExeServer>
          </com:ComServer>
        </com:Extension>
        <uap3:Extension Category="windows.appExtension">
          <uap3:AppExtension Name="com.microsoft.commandpalette"
            Id="HomeAssistant"
            PublicFolder="Public"
            DisplayName="Home Assistant"
            Description="Control Home Assistant devices from PowerToys Command Palette">
            <uap3:Properties>
              <CmdPalProvider>
                <Activation>
                  <CreateInstance ClassId="30267078-f12e-4d02-bec1-90657a71e804" />
                </Activation>
                <SupportedInterfaces>
                  <Commands/>
                </SupportedInterfaces>
              </CmdPalProvider>
            </uap3:Properties>
          </uap3:AppExtension>
        </uap3:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <Capability Name="internetClient" />
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
